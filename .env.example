# ── Summarization ────────────────────────────────────────────────────────────
# ── Summarization ────────────────────────────────────────────────────────────
# Leave blank to use the built-in deterministic fallback (no API key needed).
OPENAI_API_KEY=
# Model name; defaults to gpt-4o-mini when key is set
OPENAI_MODEL=gpt-4o-mini
# Override base URL to use any OpenAI-compatible endpoint (e.g. Azure, Ollama, LiteLLM)
OPENAI_BASE_URL=

# ── Twitter / Nitter / RSSHub feeds ──────────────────────────────────────────
# Comma-separated list of RSS feed URLs to pull Twitter-style content from.
# Examples using public Nitter mirrors or RSSHub:
#   https://nitter.net/OpenAI/rss
#   https://rsshub.app/twitter/user/karpathy
# Leave blank to skip Twitter section.
TWITTER_RSS_FEEDS=

# ── AI News RSS feeds ─────────────────────────────────────────────────────────
# Comma-separated list of additional AI news RSS feed URLs.
# Built-in defaults are used when this is empty; set to override entirely.
AI_NEWS_RSS_FEEDS=

# ── GitHub Trending ───────────────────────────────────────────────────────────
# Comma-separated language filters, e.g. "python,typescript" (leave blank for all)
GITHUB_TRENDING_LANGUAGES=
# Time range: daily | weekly | monthly
GITHUB_TRENDING_SINCE=daily

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
# ISO 8601 timezone for digest timestamp (display only)
DIGEST_TIMEZONE=Asia/Taipei

# ── Discord (optional) ────────────────────────────────────────────────────────
# Set to post the digest to a Discord channel via webhook.
DISCORD_WEBHOOK_URL=

# ── Digest tuning ─────────────────────────────────────────────────────────────
# Max items per source section
MAX_ITEMS_PER_SOURCE=10
# Max characters per item description (deterministic fallback)
MAX_DESCRIPTION_CHARS=300
